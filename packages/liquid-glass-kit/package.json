{
  "name": "liquid-glass-kit",
  "version": "1.0.0",
  "description": "Apple Liquid Glass for React Native and Expo — real UIGlassEffect on iOS 26+, self-contained AGSL refraction shaders on Android 13+, graceful degradation everywhere else. One package, both platforms, zero native setup.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc"
  },
  "keywords": [
    "react-native",
    "expo",
    "liquid-glass",
    "liquidglass",
    "glassmorphism",
    "blur",
    "ios26",
    "uiglasseffect",
    "agsl",
    "android"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/Abdullajon1881/LiquidGlass#readme",
  "bugs": {
    "url": "https://github.com/Abdullajon1881/LiquidGlass/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abdullajon1881/LiquidGlass.git",
    "directory": "packages/liquid-glass-kit"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "dependencies": {
    "expo-modules-core": "~2.1.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "typescript": "~5.6.0"
  },
  "files": [
    "build",
    "android",
    "ios",
    "src",
    "expo-module.config.json",
    "README.md"
  ]
}
